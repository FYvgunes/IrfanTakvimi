[
  { "id": 1,  "arabic": "اَللّٰهُ",                       "translit": "Allâh",              "meaning": "Bütün isimleri kapsayan, ibadet edilmeye yegâne lâyık olan; varlığı zâtından." },
  { "id": 2,  "arabic": "اَلرَّحْمٰنُ",                   "translit": "Er-Rahmân",          "meaning": "Dünyada bütün yaratılmışlara merhameti her şeyi kuşatan." },
  { "id": 3,  "arabic": "اَلرَّحِيمُ",                   "translit": "Er-Rahîm",           "meaning": "Âhirette mü'minlere özel rahmetiyle muamele eden." },
  { "id": 4,  "arabic": "اَلْمَلِكُ",                    "translit": "El-Melik",           "meaning": "Mülkün ve kâinatın gerçek sahibi, hükümdarı." },
  { "id": 5,  "arabic": "اَلْقُدُّوسُ",                  "translit": "El-Kuddûs",          "meaning": "Her türlü eksiklikten münezzeh, mutlak temiz ve mukaddes." },
  { "id": 6,  "arabic": "اَلسَّلَامُ",                   "translit": "Es-Selâm",           "meaning": "Her türlü tehlikeden selâmette olan; kullarına selâmet veren." },
  { "id": 7,  "arabic": "اَلْمُؤْمِنُ",                  "translit": "El-Mü'min",          "meaning": "Güven veren, kullarını her türlü korkudan emin kılan." },
  { "id": 8,  "arabic": "اَلْمُهَيْمِنُ",               "translit": "El-Müheymin",        "meaning": "Her şeyi görüp gözeten, koruyan ve denetleyen." },
  { "id": 9,  "arabic": "اَلْعَزِيزُ",                  "translit": "El-Azîz",            "meaning": "Mutlak galip; hiçbir şey kendisine karşı koyamayan." },
  { "id": 10, "arabic": "اَلْجَبَّارُ",                 "translit": "El-Cebbâr",          "meaning": "Dilediğini zorla yaptırmaya muktedir; kırılanı onaran." },
  { "id": 11, "arabic": "اَلْمُتَكَبِّرُ",              "translit": "El-Mütekebbir",      "meaning": "Büyüklük ve azamette eşi olmayan; kibriyâ sahibi." },
  { "id": 12, "arabic": "اَلْخَالِقُ",                  "translit": "El-Hâlık",           "meaning": "Yoktan var eden, takdir ettiği ölçüde yaratan." },
  { "id": 13, "arabic": "اَلْبَارِئُ",                  "translit": "El-Bârî",            "meaning": "Yarattığı her şeyi birbirinden farklı kusursuz biçimde var eden." },
  { "id": 14, "arabic": "اَلْمُصَوِّرُ",                "translit": "El-Musavvir",        "meaning": "Her varlığa biçim ve sûret veren." },
  { "id": 15, "arabic": "اَلْغَفَّارُ",                 "translit": "El-Gaffâr",          "meaning": "Günahları tekrar tekrar bağışlayan." },
  { "id": 16, "arabic": "اَلْقَهَّارُ",                 "translit": "El-Kahhâr",          "meaning": "Her şeye kahredici güçle galip gelen." },
  { "id": 17, "arabic": "اَلْوَهَّابُ",                 "translit": "El-Vehhâb",          "meaning": "Karşılıksız bol bol bağışta bulunan." },
  { "id": 18, "arabic": "اَلرَّزَّاقُ",                 "translit": "Er-Rezzâk",          "meaning": "Bütün canlıların rızkını veren." },
  { "id": 19, "arabic": "اَلْفَتَّاحُ",                 "translit": "El-Fettâh",          "meaning": "Kapalı olanı açan; hayır ve rahmet kapılarını gösteren." },
  { "id": 20, "arabic": "اَلْعَلِيمُ",                  "translit": "El-Alîm",            "meaning": "Her şeyi en ince ayrıntısıyla bilen." },
  { "id": 21, "arabic": "اَلْقَابِضُ",                  "translit": "El-Kâbız",           "meaning": "Dilediğine darlık veren; canları alan; tutan." },
  { "id": 22, "arabic": "اَلْبَاسِطُ",                  "translit": "El-Bâsıt",           "meaning": "Dilediğine bolluk ve genişlik veren." },
  { "id": 23, "arabic": "اَلْخَافِضُ",                  "translit": "El-Hâfıd",           "meaning": "Dilediğini alçaltan, yüksekteki şeyleri indiren." },
  { "id": 24, "arabic": "اَلرَّافِعُ",                  "translit": "Er-Râfi",            "meaning": "Dilediğini yükselten, derecesini artıran." },
  { "id": 25, "arabic": "اَلْمُعِزُّ",                  "translit": "El-Muizz",           "meaning": "Dilediğini izzet ve şerefe ulaştıran." },
  { "id": 26, "arabic": "اَلْمُذِلُّ",                  "translit": "El-Müzill",          "meaning": "Dilediğini zillete düşüren." },
  { "id": 27, "arabic": "اَلسَّمِيعُ",                  "translit": "Es-Semî'",           "meaning": "Her sesi, her duayı işiten." },
  { "id": 28, "arabic": "اَلْبَصِيرُ",                  "translit": "El-Basîr",           "meaning": "Her şeyi en ince noktasına kadar gören." },
  { "id": 29, "arabic": "اَلْحَكَمُ",                   "translit": "El-Hakem",           "meaning": "Hükmü mutlak olan; son sözü söyleyen hâkim." },
  { "id": 30, "arabic": "اَلْعَدْلُ",                   "translit": "El-Adl",             "meaning": "Mutlak adalet sahibi; asla zulmetmeyen." },
  { "id": 31, "arabic": "اَللَّطِيفُ",                  "translit": "El-Latîf",           "meaning": "Kullarına lütufla muamele eden; en gizli incelikleri bilen." },
  { "id": 32, "arabic": "اَلْخَبِيرُ",                  "translit": "El-Habîr",           "meaning": "Her şeyin iç yüzünden, gizli yönünden haberdar." },
  { "id": 33, "arabic": "اَلْحَلِيمُ",                  "translit": "El-Halîm",           "meaning": "Cezayı hak edenleri hemen cezalandırmayan, yumuşaklıkla muamele eden." },
  { "id": 34, "arabic": "اَلْعَظِيمُ",                  "translit": "El-Azîm",            "meaning": "Zâtında ve sıfatlarında en büyük olan." },
  { "id": 35, "arabic": "اَلْغَفُورُ",                  "translit": "El-Gafûr",           "meaning": "Çokça bağışlayan, mağfireti bol olan." },
  { "id": 36, "arabic": "اَلشَّكُورُ",                  "translit": "Eş-Şekûr",           "meaning": "Az amele bile çokça karşılık veren." },
  { "id": 37, "arabic": "اَلْعَلِيُّ",                  "translit": "El-Aliyy",           "meaning": "Her şeyden üstün; mertebesi yüce olan." },
  { "id": 38, "arabic": "اَلْكَبِيرُ",                  "translit": "El-Kebîr",           "meaning": "Büyüklükte eşi ve benzeri olmayan." },
  { "id": 39, "arabic": "اَلْحَفِيظُ",                  "translit": "El-Hafîz",           "meaning": "Her şeyi koruyan, gözeten, kaybolmaktan muhafaza eden." },
  { "id": 40, "arabic": "اَلْمُقِيتُ",                  "translit": "El-Mukît",           "meaning": "Bütün canlıların gıdasını veren ve gözeten." },
  { "id": 41, "arabic": "اَلْحَسِيبُ",                  "translit": "El-Hasîb",           "meaning": "Kullarının her amelini hesaba çeken." },
  { "id": 42, "arabic": "اَلْجَلِيلُ",                  "translit": "El-Celîl",           "meaning": "Celâl ve azamet sahibi; ululuğu sonsuz." },
  { "id": 43, "arabic": "اَلْكَرِيمُ",                  "translit": "El-Kerîm",           "meaning": "Cömertliği ve ihsanı bol olan." },
  { "id": 44, "arabic": "اَلرَّقِيبُ",                  "translit": "Er-Rakîb",           "meaning": "Her şeyi gözeten; hiçbir şey gözünden kaçmayan." },
  { "id": 45, "arabic": "اَلْمُجِيبُ",                  "translit": "El-Mucîb",           "meaning": "Duâları kabul eden; isteğe icabet eden." },
  { "id": 46, "arabic": "اَلْوَاسِعُ",                  "translit": "El-Vâsi'",           "meaning": "İlmi, rahmeti ve mağfireti geniş olan." },
  { "id": 47, "arabic": "اَلْحَكِيمُ",                  "translit": "El-Hakîm",           "meaning": "Hikmetle iş gören; her şeyi yerli yerinde yapan." },
  { "id": 48, "arabic": "اَلْوَدُودُ",                  "translit": "El-Vedûd",           "meaning": "Sâlih kullarını seven ve sevilmeye en lâyık olan." },
  { "id": 49, "arabic": "اَلْمَجِيدُ",                  "translit": "El-Mecîd",           "meaning": "Şânı ve şerefi yüce olan." },
  { "id": 50, "arabic": "اَلْبَاعِثُ",                  "translit": "El-Bâis",            "meaning": "Ölüleri dirilten; peygamberleri gönderen." },
  { "id": 51, "arabic": "اَلشَّهِيدُ",                  "translit": "Eş-Şehîd",           "meaning": "Her zaman ve her yerde hâzır ve nâzır olan." },
  { "id": 52, "arabic": "اَلْحَقُّ",                    "translit": "El-Hakk",            "meaning": "Varlığı hak olan; her hakkın kaynağı." },
  { "id": 53, "arabic": "اَلْوَكِيلُ",                  "translit": "El-Vekîl",           "meaning": "Kendisine tevekkül edenlerin işini yoluna koyan." },
  { "id": 54, "arabic": "اَلْقَوِيُّ",                  "translit": "El-Kaviyy",          "meaning": "Sonsuz kuvvet sahibi olan." },
  { "id": 55, "arabic": "اَلْمَتِينُ",                  "translit": "El-Metîn",           "meaning": "Kudretinde son derece sağlam; hiç zayıflamayan." },
  { "id": 56, "arabic": "اَلْوَلِيُّ",                  "translit": "El-Veliyy",          "meaning": "Mü'minlerin dostu, yardımcısı, koruyucusu." },
  { "id": 57, "arabic": "اَلْحَمِيدُ",                  "translit": "El-Hamîd",           "meaning": "Hamde ve övgüye en lâyık olan." },
  { "id": 58, "arabic": "اَلْمُحْصِي",                  "translit": "El-Muhsî",           "meaning": "Her şeyi tek tek sayan; ilmiyle kuşatan." },
  { "id": 59, "arabic": "اَلْمُبْدِئُ",                 "translit": "El-Mübdi'",          "meaning": "Mahlûkatı yoktan, örneksiz yaratan." },
  { "id": 60, "arabic": "اَلْمُعِيدُ",                  "translit": "El-Muîd",            "meaning": "Yarattığı her şeyi ölümünden sonra tekrar dirilten." },
  { "id": 61, "arabic": "اَلْمُحْيِي",                  "translit": "El-Muhyî",           "meaning": "Hayat veren; ölüleri dirilten." },
  { "id": 62, "arabic": "اَلْمُمِيتُ",                  "translit": "El-Mümît",           "meaning": "Ölümü yaratan; dilediğinin canını alan." },
  { "id": 63, "arabic": "اَلْحَيُّ",                    "translit": "El-Hayy",            "meaning": "Diri; hayatı ezelî ve ebedî olan." },
  { "id": 64, "arabic": "اَلْقَيُّومُ",                 "translit": "El-Kayyûm",          "meaning": "Bütün varlıkları ayakta tutan; kendisi için kimseye muhtaç olmayan." },
  { "id": 65, "arabic": "اَلْوَاجِدُ",                  "translit": "El-Vâcid",           "meaning": "Hiçbir şeye muhtaç olmayan; dilediği her şey önünde hâzır olan." },
  { "id": 66, "arabic": "اَلْمَاجِدُ",                  "translit": "El-Mâcid",           "meaning": "Kerem ve ihsanı bol; şânı yüce olan." },
  { "id": 67, "arabic": "اَلْوَاحِدُ",                  "translit": "El-Vâhid",           "meaning": "Zâtında, sıfatlarında ve fiillerinde tek olan." },
  { "id": 68, "arabic": "اَلصَّمَدُ",                   "translit": "Es-Samed",           "meaning": "Hiçbir şeye muhtaç olmayan; her şey kendisine muhtaç olan." },
  { "id": 69, "arabic": "اَلْقَادِرُ",                  "translit": "El-Kâdir",           "meaning": "Sonsuz kudret sahibi; her şeye gücü yeten." },
  { "id": 70, "arabic": "اَلْمُقْتَدِرُ",               "translit": "El-Muktedir",        "meaning": "Kudreti her şeye yeten; dilediğini dilediği gibi yapan." },
  { "id": 71, "arabic": "اَلْمُقَدِّمُ",                "translit": "El-Mukaddim",        "meaning": "Dilediğini öne alan, yükselten." },
  { "id": 72, "arabic": "اَلْمُؤَخِّرُ",                "translit": "El-Muahhir",         "meaning": "Dilediğini geriye bırakan." },
  { "id": 73, "arabic": "اَلْأَوَّلُ",                  "translit": "El-Evvel",           "meaning": "Başlangıcı olmayan; ezelî olan." },
  { "id": 74, "arabic": "اَلْآخِرُ",                    "translit": "El-Âhir",            "meaning": "Sonu olmayan; ebedî olan." },
  { "id": 75, "arabic": "اَلظَّاهِرُ",                  "translit": "Ez-Zâhir",           "meaning": "Varlığı her şeyden açık; delilleri âşikâr." },
  { "id": 76, "arabic": "اَلْبَاطِنُ",                  "translit": "El-Bâtın",           "meaning": "Zâtı gizli; gözle görülmeyen; gizliyi bilen." },
  { "id": 77, "arabic": "اَلْوَالِي",                   "translit": "El-Vâlî",            "meaning": "Kâinatı yöneten, idare eden." },
  { "id": 78, "arabic": "اَلْمُتَعَالِي",              "translit": "El-Müteâlî",         "meaning": "Yarattıklarına benzemekten münezzeh; son derece yüce." },
  { "id": 79, "arabic": "اَلْبَرُّ",                    "translit": "El-Berr",            "meaning": "İyilik ve ihsanı bol olan." },
  { "id": 80, "arabic": "اَلتَّوَّابُ",                 "translit": "Et-Tevvâb",          "meaning": "Tövbeleri kabul eden." },
  { "id": 81, "arabic": "اَلْمُنْتَقِمُ",               "translit": "El-Müntakim",        "meaning": "Hak edenleri adâletiyle cezalandıran." },
  { "id": 82, "arabic": "اَلْعَفُوُّ",                  "translit": "El-Afüvv",           "meaning": "Günahları affeden, silen." },
  { "id": 83, "arabic": "اَلرَّؤُوفُ",                  "translit": "Er-Raûf",            "meaning": "Çok şefkatli; kullarına çok merhametli." },
  { "id": 84, "arabic": "مَالِكُ الْمُلْكِ",            "translit": "Mâlikü'l-Mülk",      "meaning": "Bütün mülkün gerçek sahibi olan." },
  { "id": 85, "arabic": "ذُو الْجَلَالِ وَالْإِكْرَامِ", "translit": "Zü'l-Celâli ve'l-İkrâm", "meaning": "Celâl, azamet ve ikrâm sahibi olan." },
  { "id": 86, "arabic": "اَلْمُقْسِطُ",                 "translit": "El-Muksit",          "meaning": "Adâletle hükmeden; her hak sahibine hakkını veren." },
  { "id": 87, "arabic": "اَلْجَامِعُ",                  "translit": "El-Câmi'",           "meaning": "İstediğini istediği yerde toplayan; mahşerde kulları toplayacak olan." },
  { "id": 88, "arabic": "اَلْغَنِيُّ",                  "translit": "El-Ganiyy",          "meaning": "Hiçbir şeye muhtaç olmayan; mutlak zengin." },
  { "id": 89, "arabic": "اَلْمُغْنِي",                  "translit": "El-Muğnî",           "meaning": "Dilediğini zengin eden." },
  { "id": 90, "arabic": "اَلْمَانِعُ",                  "translit": "El-Mâni'",           "meaning": "Dilediği şeylerin meydana gelmesine engel olan." },
  { "id": 91, "arabic": "اَلضَّارُّ",                   "translit": "Ed-Dârr",            "meaning": "Elem ve zarar verici şeyleri yaratan." },
  { "id": 92, "arabic": "اَلنَّافِعُ",                  "translit": "En-Nâfi'",           "meaning": "Faydalı şeyleri yaratan; fayda veren." },
  { "id": 93, "arabic": "اَلنُّورُ",                    "translit": "En-Nûr",             "meaning": "Âlemleri nurlandıran; hidâyete erdiren." },
  { "id": 94, "arabic": "اَلْهَادِي",                   "translit": "El-Hâdî",            "meaning": "Kullarına doğru yolu gösteren; hidâyet veren." },
  { "id": 95, "arabic": "اَلْبَدِيعُ",                  "translit": "El-Bedî'",           "meaning": "Eşi ve benzeri olmadan eşsiz şeyler yaratan." },
  { "id": 96, "arabic": "اَلْبَاقِي",                   "translit": "El-Bâkî",            "meaning": "Varlığı sonsuza dek sürecek olan." },
  { "id": 97, "arabic": "اَلْوَارِثُ",                  "translit": "El-Vâris",           "meaning": "Bütün mülkün son sahibi; her şeyin mirasçısı." },
  { "id": 98, "arabic": "اَلرَّشِيدُ",                  "translit": "Er-Reşîd",           "meaning": "İrşâd edici; doğru yolu gösteren; işleri hayırla sonuçlandıran." },
  { "id": 99, "arabic": "اَلصَّبُورُ",                  "translit": "Es-Sabûr",           "meaning": "Çok sabırlı; cezalandırmada acele etmeyen." }
]
